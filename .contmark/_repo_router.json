  "flows": [
    {
      "name": "offer-search-master-data",
      "description": "Web-integrator runs an offer search via offer-service, which enriches results from master data.",
      "triggers": [
        "offer search enrichment",
        "search service plans",
        "offer master data lookup",
        "charge type resolution offer",
        "commodity validation offer",
        "location enrichment search"
      ],
      "repo_chain": [
        "iom-web-integrator",
        "iom-offer-service",
        "iom-master-data"
      ],
      "topics": [
        {
          "topic": "services.offer.base-url",
          "protocol": "rest",
          "from": "iom-web-integrator",
          "to": "iom-offer-service",
          "schema_path": "repos/iom-offer-service/contracts/api-contracts.md"
        },
        {
          "topic": "maersk.masterdata-base-url",
          "protocol": "rest",
          "from": "iom-offer-service",
          "to": "iom-master-data",
          "schema_path": "repos/iom-master-data/contracts/api-contracts-1.md"
        }
      ],
      "entry_files": {
        "iom-web-integrator": "runtime/offer-search-flow.md",
        "iom-offer-service": "runtime/offer-search-flow.md",
        "iom-master-data": "runtime/charge-type-query-flow.md"
      }
    },
    {
      "name": "offer-search-facility",
      "description": "Web-integrator offer search calls offer-service, which looks up facility data from SMDS facilities.",
      "triggers": [
        "facility lookup in search",
        "offer facility enrichment",
        "facility data for offer",
        "smds facility search",
        "facility vs city location",
        "inland facility resolution"
      ],
      "repo_chain": [
        "iom-web-integrator",
        "iom-offer-service",
        "smds-facilities-service"
      ],
      "topics": [
        {
          "topic": "services.offer.base-url",
          "protocol": "rest",
          "from": "iom-web-integrator",
          "to": "iom-offer-service",
          "schema_path": "repos/iom-offer-service/contracts/api-contracts.md"
        },
        {
          "topic": "smds facilities lookup",
          "protocol": "rest",
          "from": "iom-offer-service",
          "to": "smds-facilities-service",
          "schema_path": "repos/smds-facilities-service/contracts/api-contracts.md"
        }
      ],
      "entry_files": {
        "iom-web-integrator": "runtime/offer-search-flow.md",
        "iom-offer-service": "runtime/offer-search-flow.md",
        "smds-facilities-service": "runtime/facility-search-flow.md"
      }
    },
    {
      "name": "service-plan-save-to-publish",
      "description": "Order-service stages a service-plan domain event to the outbox; the scheduler publishes it to Kafka, where offer-service consumes it.",
      "triggers": [
        "service plan saved event",
        "outbox to kafka publish",
        "domain event publishing",
        "offered plan number update",
        "service plan number linking",
        "outbox message processing"
      ],
      "repo_chain": [
        "iom-order-service",
        "iom-order-service-scheduler",
        "iom-offer-service"
      ],
      "topics": [
        {
          "topic": "outbox_messages",
          "protocol": "outbox-db",
          "from": "iom-order-service",
          "to": "iom-order-service-scheduler",
          "schema_path": "repos/iom-order-service/contracts/kafka-events.md"
        },
        {
          "topic": "iom-serviceplan-domain-event-topic.local.v1",
          "protocol": "kafka",
          "from": "iom-order-service-scheduler",
          "to": "iom-offer-service",
          "schema_path": "repos/iom-order-service-scheduler/contracts/kafka-events.md"
        }
      ],
      "entry_files": {
        "iom-order-service": "runtime/service-plan-domain-event-flow.md",
        "iom-order-service-scheduler": "runtime/event-activity-matrix.md",
        "iom-offer-service": "runtime/service-plan-event-processing-flow.md"
      }
    },
    {
      "name": "repricing-scheduler-to-order",
      "description": "The scheduler runs a Temporal repricing workflow that PATCH-calls web-integrator, which updates the service plan on order-service.",
      "triggers": [
        "repricing workflow execution",
        "reprice service plan",
        "temporal repricing flow",
        "vessel eta repricing",
        "container count repricing",
        "reprice patch call"
      ],
      "repo_chain": [
        "iom-order-service-scheduler",
        "iom-web-integrator",
        "iom-order-service"
      ],
      "topics": [
        {
          "topic": "PATCH /service-plans/{servicePlanNumber}/reprice",
          "protocol": "rest",
          "from": "iom-order-service-scheduler",
          "to": "iom-web-integrator",
          "schema_path": "repos/iom-web-integrator/contracts/api-contracts-1.md"
        },
        {
          "topic": "services.order.base-url",
          "protocol": "rest",
          "from": "iom-web-integrator",
          "to": "iom-order-service",
          "schema_path": "repos/iom-order-service/contracts/api-contracts.md"
        }
      ],
      "entry_files": {
        "iom-order-service-scheduler": "runtime/repricing-flow.md",
        "iom-web-integrator": "runtime/repricing-flow.md",
        "iom-order-service": "runtime/order-creation-flow.md"
      }
    },
    {
      "name": "offer-cleanup-scheduler",
      "description": "The scheduler periodically calls offer-service to delete stale offered-service-plan records, which themselves were enriched from master data.",
      "triggers": [
        "offer cleanup flow",
        "delete offered plans",
        "stale offer cleanup",
        "scheduled offer deletion",
        "offered plan cleanup job",
        "old offer record removal"
      ],
      "repo_chain": [
        "iom-order-service-scheduler",
        "iom-offer-service",
        "iom-master-data"
      ],
      "topics": [
        {
          "topic": "DELETE offered-service-plans?numberOfDays=",
          "protocol": "rest",
          "from": "iom-order-service-scheduler",
          "to": "iom-offer-service",
          "schema_path": "repos/iom-offer-service/contracts/api-contracts.md"
        },
        {
          "topic": "maersk.masterdata-base-url",
          "protocol": "rest",
          "from": "iom-offer-service",
          "to": "iom-master-data",
          "schema_path": "repos/iom-master-data/contracts/api-contracts-1.md"
        }
      ],
      "entry_files": {
        "iom-order-service-scheduler": "runtime/repricing-flow.md",
        "iom-offer-service": "runtime/offer-cleanup-flow.md",
        "iom-master-data": "runtime/location-search-flow.md"
      }
    },
    {
      "name": "booking-web-integrator-to-scheduler",
      "description": "A booking created via web-integrator persists a service plan in order-service, which stages outbound events for the scheduler.",
      "triggers": [
        "create booking order",
        "service plan crud",
        "order status update",
        "booking to outbox",
        "order save flow",
        "service plan persistence"
      ],
      "repo_chain": [
        "iom-web-integrator",
        "iom-order-service",
        "iom-order-service-scheduler"
      ],
      "topics": [
        {
          "topic": "services.order.base-url",
          "protocol": "rest",
          "from": "iom-web-integrator",
          "to": "iom-order-service",
          "schema_path": "repos/iom-order-service/contracts/api-contracts.md"
        },
        {
          "topic": "outbox_messages",
          "protocol": "outbox-db",
          "from": "iom-order-service",
          "to": "iom-order-service-scheduler",
          "schema_path": "repos/iom-order-service/contracts/kafka-events.md"
        }
      ],
      "entry_files": {
        "iom-web-integrator": "runtime/booking-creation-flow.md",
        "iom-order-service": "runtime/order-creation-flow.md",
        "iom-order-service-scheduler": "runtime/event-activity-matrix.md"
      }
    }
  ],
  "per_repo_summary": {
    "iom-web-integrator": "Frontend-facing integration layer (BFF). Owns ocean-booking creation, booking-request shaping, user-preferences, decisioning/business-rules, and orchestration of offer-search and order/service-plan calls. Calls offer-service and order-service; does NOT own offer computation or service-plan persistence.",
    "iom-offer-service": "Owns inland offer search, rate calculation, repricing response, and offered-service-plan persistence (MongoDB). Calls OIPO offer/rates/routing externally and master-data + SMDS facilities for enrichment; consumes the service-plan domain-event topic to link offered plans to booked service-plan numbers. Does NOT own service-plan CRUD.",
    "iom-order-service": "Owns service-plan / order CRUD, status, dashboard search, incidents, finops, and Kafka consumption of booking + service-plan-domain + customer-history events. Stages outbound domain events into the outbox table; does NOT publish Kafka directly (the scheduler does).",
    "iom-order-service-scheduler": "The outbox publisher and scheduled-job host for the order side. Reads outbox_messages and publishes service-plan / domain-event / booking Kafka topics, runs offer cleanup (DELETE to offer-service), and runs Temporal repricing workflows that PATCH web-integrator. Owns no REST query API of its own.",
    "iom-master-data": "IOM Master Data Service. Owns reference domains: locations, commodities, container types, charge types, vessels, sales objects, vendors, diesel price ranges. Read by offer-service for enrichment. A multi-module Gradle project split by domain.",
    "smds-facilities-service": "SMDS facilities service. Owns facility data, facility categories, customer-access, and geographic details, with fuzzy + id-based facility search. Read by offer-service during offer-search location enrichment.",
    "iom-application": "Shared multi-module Gradle library (NOT a deployable service) holding the cross-cutting IOM domain model: booking, equipment, location, party, product-offer, service-plan. No REST controllers at root level; consumed as a dependency."
  },
  "disambiguation_rules": [
    {
      "token": "reprice",
      "default_repo": "iom-order-service-scheduler",
      "rule": "Repricing is INITIATED by the scheduler (RepricingScheduler + Temporal RepricingWorkflow). The scheduler-side work (workflow execution, scheduling, task queue) lives in iom-order-service-scheduler. The repricing HTTP endpoint that actually recomputes and persists the service plan (PATCH /service-plans/{n}/reprice) lives in iom-web-integrator.",
      "scheduler_marker_phrases": [
        "repricing workflow",
        "repricing task queue",
        "temporal repricing",
        "reprice scheduler"
      ],
      "web_integrator_marker_phrases": [
        "reprice endpoint",
        "reprice patch",
        "service plan reprice api"
      ],
      "repos": [
        "iom-order-service-scheduler",
        "iom-web-integrator"
      ]
    },
    {
      "token": "repricing",
      "default_repo": "iom-order-service-scheduler",
      "rule": "Same split as \"reprice\": scheduling/workflow in iom-order-service-scheduler; the repricing REST handler in iom-web-integrator.",
      "scheduler_marker_phrases": [
        "repricing workflow",
        "repricing task queue",
        "temporal repricing"
      ],
      "web_integrator_marker_phrases": [
        "repricing endpoint",
        "repricing api"
      ],
      "repos": [
        "iom-order-service-scheduler",
        "iom-web-integrator"
      ]
    }
  ]
}
